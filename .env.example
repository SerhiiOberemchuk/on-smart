# on-smart environment variables — NAMES ONLY, never commit real values.
# Copy to .env.local for development. Inventory matches actual process.env.* usage in code.

# ── Database (MySQL, db/db.ts + drizzle.config.ts) ──────────────────────────
DATABASE_HOST=
DATABASE_PORT=
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=
# Optional pool tuning (db/db.ts)
DATABASE_POOL_LIMIT=
DATABASE_POOL_MAX_IDLE=
DATABASE_POOL_IDLE_TIMEOUT_MS=

# ── Auth (Better Auth, lib/auth.ts) ─────────────────────────────────────────
BETTER_AUTH_SECRET=
# Public origin of the app (e.g. https://on-smart.it). Read by Better Auth;
# explicitly required from client-accounts spec Phase 1 (docs/specs/client-accounts/01-auth.md).
BETTER_AUTH_URL=
# Comma-separated emails that get role=admin at registration (admin-panel access).
# See lib/admin-emails.ts and client-accounts spec decision #17.
ADMIN_EMAILS=

# ── Mail (SMTP, lib/mail-transporter.ts) ────────────────────────────────────
MAIL_HOST=
MAIL_PORT=
MAIL_USER_ORDERS=
MAIL_PASSWORD_ORDERS=
MAIL_USER_ASSISTENZA=
MAIL_PASSWORD_ASSISTENZA=
# Gmail app password for transporterGoogle
MAIL_SMTP_GMAIL_PASSWORD=

# ── Payments ────────────────────────────────────────────────────────────────
# PayPal (lib/paypal.ts): PAYPAL_ENV = sandbox | production
PAYPAL_ENV=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# SumUp — two naming sets are in use (known inconsistency, functionality.md §9):
# app/actions/sumup/action.ts reads SUMUP_*, app/actions/sumup/sumup-constans.ts reads SUM_UP_*
SUMUP_API_KEY=
SUMUP_MERCHANT_CODE=
SUM_UP_MERCHANT_CODE=
SUM_UP_ACCESS_TOKEN=
# Klarna (lib/klarna.ts)
KLARNA_API_BASE=
KLARNA_USERNAME=
KLARNA_PASSWORD=

# ── File storage (Aruba S3, lib/s3-files.ts) ────────────────────────────────
S3_REGION=
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ── Notifications / analytics / reviews ─────────────────────────────────────
TG_BOT_TOKEN=
TG_CHAT_ID=
GOOGLE_GTAG=
APIFY_API_TOKEN=
APIFY_TASK_ID=

# ── Legacy / dead code (kept for reference; see functionality.md §9) ────────
# ODOO — dead experiment in app/actions/test.ts
ODOO=
# API_URL / API_TOKEN — commented-out fetch in components/home-sections/google-review-section/ReviewList/action.ts
API_URL=
API_TOKEN=
